#!/bin/bash
SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
INSTALL_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

if [ ! -f "$INSTALL_DIR/server.js" ]; then
  echo "Mercury ACH not found. Install with:"
  echo "  curl -fsSL https://raw.githubusercontent.com/CashQ/mercury/main/install.sh | bash"
  exit 1
fi

cd "$INSTALL_DIR"
echo "Mercury ACH starting at http://localhost:${PORT:-3000}"
node server.js
